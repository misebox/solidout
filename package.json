{
  "name": "soluid",
  "version": "0.2.1",
  "type": "module",
  "description": "CLI that installs SolidJS UI components directly into your project — own the code, no runtime dependency",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/misebox/soluid.git"
  },
  "homepage": "https://github.com/misebox/soluid",
  "keywords": [
    "solidjs",
    "solid-js",
    "ui-components",
    "component-library",
    "cli",
    "code-generation",
    "design-system",
    "typescript",
    "css-variables",
    "theming",
    "accessible",
    "shadcn"
  ],
  "bin": {
    "soluid": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "bun run precatalog && vite --open /soluid/ --base /soluid",
    "generate:css": "bunx tsx scripts/generate-css-imports.ts",
    "generate:api": "bunx tsx scripts/generate-api-data.ts",
    "precatalog": "bun run generate:css && bun run generate:api",
    "build:catalog": "bun run precatalog && vite build --config vite.config.catalog.ts",
    "build:cli": "tsc -p cli/tsconfig.json",
    "prepare": "bun run build:cli",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "fmt": "oxfmt src/ cli/ scripts/",
    "fmt:check": "oxfmt --check src/ cli/ scripts/",
    "lint": "oxlint src/ cli/",
    "fix": "oxlint --fix src/ cli/ && oxfmt src/ cli/ scripts/",
    "verify": "concurrently -n lint,fmt,test,build \"bun run lint\" \"bun run fmt:check\" \"bun run test\" \"bun run build:cli\"",
    "ready": "bun run fix && bun run verify && bun run build:catalog && bun run fmt",
    "push:check": "sh bin/check-build-freshness.sh"
  },
  "devDependencies": {
    "@floating-ui/dom": "^1.7.5",
    "@solid-primitives/active-element": "^2.1.5",
    "@solid-primitives/event-listener": "^2.4.5",
    "@solid-primitives/scheduled": "^1.5.3",
    "@solidjs/router": "^0.15.4",
    "@types/node": "^20.19.34",
    "concurrently": "^9.2.1",
    "oxfmt": "^0.41.0",
    "oxlint": "^1.50.0",
    "solid-js": "^1.9.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-solid": "^2.11.0",
    "vitest": "^4.1.0"
  },
  "dependencies": {
    "tar": "^7.5.9"
  }
}
